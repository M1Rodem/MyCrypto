{
  "openapi": "3.0.4",
  "info": {
    "title": "Crypto API",
    "description": "API for encryption using Custom and ChaCha20 algorithms",
    "version": "v1"
  },
  "paths": {
    "/api/Crypto/encrypt": {
      "post": {
        "tags": [
          "Crypto"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EncryptRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EncryptRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EncryptRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Crypto/decrypt": {
      "post": {
        "tags": [
          "Crypto"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DecryptRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DecryptRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DecryptRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Crypto/generate-key": {
      "get": {
        "tags": [
          "Crypto"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/": {
      "get": {
        "tags": [
          "CryptoApi"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DecryptRequest": {
        "required": [
          "encryptedText",
          "key"
        ],
        "type": "object",
        "properties": {
          "encryptedText": {
            "minLength": 1,
            "type": "string"
          },
          "key": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "EncryptRequest": {
        "required": [
          "key",
          "text"
        ],
        "type": "object",
        "properties": {
          "text": {
            "minLength": 1,
            "type": "string"
          },
          "key": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Crypto"
    },
    {
      "name": "CryptoApi"
    }
  ]
}